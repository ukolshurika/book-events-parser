# AWS S3 Configuration
AWS_BUCKET=history-prism-dev

# YandexGPT API Configuration
YANDEX_API_KEY=your-yandex-api-key-here
YANDEX_FOLDER_ID=your-yandex-folder-id-here

# Events Endpoint Configuration
EVENTS_ENDPOINT=https://your-website.com/books/events

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/history_prism

# Cache TTL (days before processed pages are deleted)
CACHE_TTL_DAYS=14
